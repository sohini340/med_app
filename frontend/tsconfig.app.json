{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",

    "jsx": "react-jsx",
    "useDefineForClassFields": true,

    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "noEmit": true,

    /* paths */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    /* relaxed for now */
    "strict": false,
    "skipLibCheck": true,

    "types": ["vitest/globals"]
  },
  "include": ["src"]
}